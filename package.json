{
  "name": "poultry-os",
  "description": "a poultry management web app",
  "version": "0.0.0",
  "homepage": "",
  "private": true,
  "main": "src",
  "keywords": [
    "feathers"
  ],
  "author": {
    "name": "Shehabedin Ahmed",
    "email": "shehabedinali@gmail.com"
  },
  "contributors": [],
  "bugs": {},
  "directories": {
    "lib": "src",
    "test": "test/",
    "config": "config/"
  },
  "engines": {
    "node": "^20.0.0",
    "npm": ">= 3.0.0"
  },
  "scripts": {
    "test": "npm run lint && npm run compile && npm run mocha",
    "lint": "eslint src/. test/. --config .eslintrc.json --ext .ts --fix",
    "dev": "ts-node-dev --no-notify src/",
    "start": "node lib/",
    "mocha": "mocha --require ts-node/register --require source-map-support/register \"test/**/*.ts\" --recursive --exit",
    "compile": "shx rm -rf lib/ && tsc",
    "install:admin": "cd admin && npm install",
    "build:admin": "cd admin && npm run build && cd ..",
    "build": "npm run install:admin && npm run build:admin && npm run compile"
  },
  "standard": {
    "env": [
      "mocha"
    ],
    "ignore": []
  },
  "types": "lib/",
  "dependencies": {
    "@feathersjs/authentication": "^4.5.19",
    "@feathersjs/authentication-local": "^4.5.19",
    "@feathersjs/authentication-oauth": "^4.5.19",
    "@feathersjs/configuration": "^4.5.19",
    "@feathersjs/errors": "^4.5.19",
    "@feathersjs/express": "^4.5.19",
    "@feathersjs/feathers": "^4.5.19",
    "@feathersjs/socketio": "^4.5.19",
    "@feathersjs/transport-commons": "^5.0.40",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "feathers-mongoose": "^8.5.1",
    "helmet": "^5.1.1",
    "mongodb-core": "^3.2.7",
    "mongoose": "^8.23.0",
    "serve-favicon": "^2.5.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/serve-favicon": "^2.5.7",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "axios": "^1.13.5",
    "eslint": "^8.57.1",
    "mocha": "^10.8.2",
    "shx": "^0.4.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
